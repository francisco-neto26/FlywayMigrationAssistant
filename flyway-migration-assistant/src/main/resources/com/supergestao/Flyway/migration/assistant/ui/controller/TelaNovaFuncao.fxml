<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="painelRaiz" alignment="CENTER" prefWidth="400.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.supergestao.Flyway.migration.assistant.ui.controller.TelaNovaFuncaoController">
    <children>
        <VBox spacing="10.0">
            <VBox.margin><Insets left="15.0" right="15.0" top="10.0" /></VBox.margin>
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Módulo:" />
                        <ComboBox fx:id="comboModulo" maxWidth="1.7976931348623157E308" promptText="Selecione o Módulo..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Nome da Função:" />
                        <TextField fx:id="txtNomeFuncao" promptText="Ex: relatorios" />
                    </children>
                </VBox>
            </children>
        </VBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <VBox.margin><Insets bottom="15.0" left="15.0" right="15.0" top="10.0" /></VBox.margin>
            <children>
                <Button fx:id="btnCancelar" onAction="#fechar" text="Cancelar" />
                <Button fx:id="btnSalvarFuncao" onAction="#salvarFuncao" text="Criar Função" />
            </children>
        </HBox>
    </children>
</VBox>
