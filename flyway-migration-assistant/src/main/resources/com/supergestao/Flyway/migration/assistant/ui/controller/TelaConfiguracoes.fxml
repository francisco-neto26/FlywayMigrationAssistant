<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="painelRaiz" alignment="CENTER" prefHeight="297.0" prefWidth="690.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.supergestao.Flyway.migration.assistant.ui.controller.TelaConfiguracoesController">
    <children>
        <VBox alignment="CENTER" prefHeight="215.0" prefWidth="525.0" spacing="15.0">
            <VBox.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </VBox.margin>
            <children>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Diretório Arquivos Migration" />
                        <HBox spacing="5.0">
                            <children>
                                <TextField fx:id="txtDiretorioArquivos" editable="false" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnProcurarDiretorioArquivos" onAction="#obterDiretorioArquivos" text="Selecionar Diretório" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Diretório dos Módulos (.JAVA):" />
                        <HBox spacing="5.0">
                            <children>
                                <TextField fx:id="txtDiretorioModulos" editable="false" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnProcurarDiretorioModulos" onAction="#obterDiretorioModulos" text="Selecionar Diretório" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Tema:" />
                                <HBox spacing="15.0">
                                    <children>
                                        <ComboBox fx:id="comboTema" onAction="#aplicarTema" prefHeight="25.0" prefWidth="230.0" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Fonte:" />
                                <HBox spacing="15.0">
                                    <children>
                                        <ComboBox fx:id="comboFonte" onAction="#aplicarfonte" prefHeight="25.0" prefWidth="230.0" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Usar diretório Modulo:" />
                                <HBox spacing="15.0">
                                    <children>
                                        <ComboBox fx:id="comboDirModulo" onAction="#usaDiretorioModulo" prefHeight="25.0" prefWidth="230.0" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <VBox spacing="5.0">
                    <children>
                        <HBox prefHeight="36.0" prefWidth="650.0" spacing="15.0">
                            <Button fx:id="btnCoresPadrao" onAction="#coresPadrao" text="Cores Padrão" />
                     <HBox alignment="TOP_RIGHT" prefHeight="25.0" prefWidth="539.0" spacing="15.0">
                        <children>
                           <Button fx:id="btnCancelar" onAction="#fechar" text="Cancelar" />
                           <Button fx:id="btnSalvar" onAction="#salvar" text="Salvar" />
                        </children>
                     </HBox>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
