<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefWidth="450.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.supergestao.Flyway.migration.assistant.ui.controller.TelaConfirmacaoController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="40.0" style="-fx-background-color: #2c3e50;">
            <children>
                <Label fx:id="lblTitulo" text="Confirmar Ação" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>
            </children>
            <padding><Insets left="15.0" /></padding>
        </HBox>
        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
            <VBox.margin><Insets left="15.0" right="15.0" /></VBox.margin>
            <children>
                <Label fx:id="lblMensagem" alignment="CENTER" prefHeight="22.0" prefWidth="423.0" text="Deseja realmente realizar esta ação?" wrapText="true" VBox.vgrow="ALWAYS">
                    <font><Font size="14.0" /></font>
                </Label>
            </children>
        </VBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <VBox.margin><Insets bottom="15.0" left="15.0" right="15.0" top="10.0" /></VBox.margin>
            <children>
                <Button fx:id="btnCancelar" prefWidth="75.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Cancelar" />
                <Button fx:id="btnConfirmar" prefWidth="75.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Confirmar" />
            </children>
        </HBox>
    </children>
</VBox>
