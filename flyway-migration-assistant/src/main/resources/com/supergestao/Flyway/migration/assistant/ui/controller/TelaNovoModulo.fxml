<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="painelRaiz" prefWidth="400.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.supergestao.Flyway.migration.assistant.ui.controller.TelaNovoModuloController">
    <children>

        <VBox spacing="5.0">
            <VBox.margin><Insets left="15.0" right="15.0" top="10.0" /></VBox.margin>
            <children>
                <Label text="Nome do Módulo:" />
                <TextField fx:id="txtNomeModulo" promptText="Ex: financeiro" />
            </children>
        </VBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <VBox.margin><Insets bottom="15.0" left="15.0" right="15.0" top="10.0" /></VBox.margin>
            <children>
                <Button fx:id="btnCancelar" onAction="#fechar" text="Cancelar" />
                <Button fx:id="btnSalvarModulo" onAction="#salvarModulo" text="Criar Módulo" />
            </children>
        </HBox>
    </children>
</VBox>
