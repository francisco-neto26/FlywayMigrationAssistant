<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" style="-fx-border-color: rgba(128, 128, 128, 0.3); -fx-border-style: solid; -fx-border-width: 1;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.supergestao.Flyway.migration.assistant.ui.controller.TelaPrincipalController">

    <center>
        <SplitPane dividerPositions="0.35">
            <items>

                <VBox maxWidth="350.0" minWidth="150.0" prefWidth="300.0" spacing="10.0" style="-fx-border-color: rgba(128, 128, 128, 0.3); -fx-border-style: solid; -fx-border-width: 0 1 0 0;">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <Label opacity="0.7" text="Explorador de Módulos E Fuções">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>

                        <HBox spacing="8.0">
                            <children>
                                <TextField fx:id="txtBuscarArquivo" promptText="Buscar arquivo..." HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnBuscar" style="-fx-cursor: hand;" text="🔍" />
                            </children>
                        </HBox>

                        <TreeView fx:id="treeArquivos" style="-fx-border-width: 0;" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <SplitPane dividerPositions="0.85" orientation="VERTICAL">
                    <items>

                        <VBox spacing="10.0">
                            <padding>
                                <Insets bottom="10.0" left="20.0" right="20.0" top="15.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label opacity="0.7" text="EDITOR SQL">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>

                                        <Region HBox.hgrow="ALWAYS" />

                                        <Button fx:id="btnIndentar" style="-fx-cursor: hand;" text="Indentar" />
                                        <Button fx:id="btnValidarSql" style="-fx-cursor: hand;" text="Validar SQL" />
                                        <Button fx:id="btnCancelarEdicao" style="-fx-cursor: hand;" text="Cancelar" />
                                        <Button fx:id="btnSalvarSql" style="-fx-cursor: hand;" text="Salvar" />
                                    </children>
                                </HBox>

                                <TextArea fx:id="txtAreaSql" promptText="Escreva ou carregue seu código SQL aqui..." style="-fx-font-family: 'Consolas'; -fx-font-size: 14px;" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <VBox maxHeight="250.0" minHeight="100.0" prefHeight="220.0" spacing="5.0" style="-fx-border-color: rgba(128, 128, 128, 0.3); -fx-border-style: solid; -fx-border-width: 1 0 0 0;">
                            <padding>
                                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                            </padding>
                            <children>
                                <Label opacity="0.7" text="SAÍDA / MENSAGENS">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font>
                                </Label>
                                <TextArea fx:id="txtAreaMensagens" editable="false" style="-fx-font-family: 'Consolas'; -fx-text-fill: #DC2626;" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                    </items>
                </SplitPane>

            </items>
        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="55.0" spacing="15.0" style="-fx-border-color: rgba(128, 128, 128, 0.3); -fx-border-style: solid; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <children>
                <Button fx:id="btnAtualizar" prefWidth="120.0" style="-fx-cursor: hand;" text="Atualizar Módulos" />

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnNovoModulo" style="-fx-cursor: hand;" text="Novo Módulo" />
                <Button fx:id="btnNovaFuncao" style="-fx-cursor: hand;" text="Nova Função" />
                <Button fx:id="btnNovoMigration" style="-fx-cursor: hand;" text="Novo Migration" />
                <Button fx:id="btnConfiguracoes" style="-fx-cursor: hand;" text="Configurações" />
            </children>
        </HBox>
    </bottom>
   <opaqueInsets>
      <Insets left="2.0" />
   </opaqueInsets>

</BorderPane>
